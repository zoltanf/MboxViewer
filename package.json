{
  "name": "mbox-viewer",
  "version": "1.6.0",
  "description": "Desktop mbox viewer for macOS",
  "author": {
    "name": "Zoltan Fekete",
    "email": "zoltan@fekete.link",
    "url": "https://github.com/zoltanf"
  },
  "license": "GPL-3.0-only",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "postinstall": "electron-builder install-app-deps",
    "icons:generate": "node scripts/generate-icons.js",
    "version:set:build": "node scripts/set-build-version.js",
    "prepare:build": "npm run version:set:build && npm run icons:generate",
    "prepack": "npm run prepare:build",
    "pack": "electron-builder --dir",
    "predist": "npm run prepare:build",
    "dist": "electron-builder --mac --win --linux",
    "predist:mac": "npm run prepare:build",
    "dist:mac": "electron-builder --mac",
    "predist:win": "npm run prepare:build",
    "dist:win": "electron-builder --win",
    "predist:linux": "npm run prepare:build",
    "dist:linux": "electron-builder --linux"
  },
  "devDependencies": {
    "electron": "^35.7.5",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.zoltanf.mboxviewer",
    "productName": "Mbox Viewer",
    "icon": "build/icon.png",
    "directories": {
      "output": "dist"
    },
    "fileAssociations": [
      {
        "ext": "mbox",
        "name": "Mbox Mailbox Archive",
        "description": "Email mailbox archive in mbox format",
        "role": "Viewer"
      },
      {
        "ext": "pst",
        "name": "Outlook PST Archive",
        "description": "Microsoft Outlook personal storage archive",
        "role": "Viewer"
      },
      {
        "ext": "eml",
        "name": "EML Message File",
        "description": "Single email message in EML format",
        "role": "Viewer"
      }
    ],
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "package.json"
    ],
    "mac": {
      "icon": "build/icon.png",
      "category": "public.app-category.productivity",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ]
    },
    "win": {
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "linux": {
      "icon": "build/icon.png",
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Office"
    }
  },
  "dependencies": {
    "better-sqlite3": "^12.6.2",
    "pst-extractor": "^1.12.0"
  }
}
